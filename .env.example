# Copy this file to .env and fill in your values
# Never commit .env to git

# ── LLM Provider ────────────────────────────────────────────────────────
# Choose one: anthropic | google | openai
#   • Local / Colab development → google   (Gemini free tier)
#   • AgentBase deployment      → openai   (VNG MaaS, OpenAI-compatible)
LLM_PROVIDER=google

# Your API key for the chosen provider:
#   anthropic → https://console.anthropic.com  (starts with sk-ant-api03-)
#   google    → https://aistudio.google.com    (starts with AIzaSy...)
#   openai    → https://platform.openai.com    (starts with sk-proj-)
#   MaaS      → created via /agentbase-llm (aip.sh api-keys create)
LLM_API_KEY=

# OpenAI-compatible base URL. Leave empty for real OpenAI.
# For AgentBase MaaS, set provider=openai and uncomment:
# LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1

# Optional: override model names (defaults are set automatically per provider)
# anthropic: claude-haiku-4-5-20251001 / claude-sonnet-4-6
# google:    gemini-2.5-flash-lite     / gemini-2.5-flash  (pro is blocked on free tier)
# openai:    gpt-4o-mini               / gpt-4o
# openai + MaaS (Gemma is the only model — same for both tiers):
#   MODEL_FAST=google/gemma-4-31b-it
#   MODEL_SMART=google/gemma-4-31b-it
# MODEL_FAST=
# MODEL_SMART=

# ── Jira ────────────────────────────────────────────────────────────────
JIRA_URL=https://your-company.atlassian.net
JIRA_EMAIL=your@email.com
JIRA_API_TOKEN=...

# ── Facebook ────────────────────────────────────────────────────────────
FB_PAGE_IDS=111111,222222,333333   # comma-separated, crawls all listed pages
FB_ACCESS_TOKEN=...

# ── Threads ─────────────────────────────────────────────────────────────
THREADS_ACCESS_TOKEN=...

# ── Database ────────────────────────────────────────────────────────────
# Local development defaults to sqlite:///data.db if DATABASE_URL is empty.
# For production (Supabase/PostgreSQL), set your connection URL:
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.ulbuhwbuanlmkhmdoekl.supabase.co:5432/postgres

# ── GitHub Action Trigger (Optional, for manual triggers from UI) ────────
# Setup these to trigger GitHub Action daily_crawl.yml pipeline from UI
# GITHUB_PAT=github_pat_xxxxxx
# GITHUB_REPO=owner/repo_name
# GITHUB_WORKFLOW=daily_crawl.yml
# GITHUB_BRANCH=main  # Optional: specify a branch name to test with (defaults to main)