# Production env for the AgentBase runtime — pass via: runtime.sh create --env-file <this>
# Copy to a real env file and fill in. Do NOT set GREENNODE_* here (auto-injected).

# ── LLM via VNG MaaS (OpenAI-compatible, single model) ──────────────────────
LLM_PROVIDER=openai
LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
LLM_API_KEY=                       # created via /agentbase-llm (aip.sh api-keys create)
MODEL_FAST=google/gemma-4-31b-it
MODEL_SMART=google/gemma-4-31b-it

# ── Data connectors (real run; omit to use dry_run mock data) ───────────────
JIRA_URL=https://your-company.atlassian.net
JIRA_EMAIL=your@email.com
JIRA_API_TOKEN=
JIRA_PROJECT=                      # optional: scope JQL to a project key
# JIRA_JQL=                        # optional: full JQL override

FB_PAGE_IDS=                       # comma-separated page IDs
FB_ACCESS_TOKEN=

THREADS_ACCESS_TOKEN=

# ── Pipeline lookback ────────────────────────────────────────────────────────
# DAYS_BACK is read from config defaults; override here if needed.
